BIOHUEZ_LEGACY_DASHBOARD_DIR=../biohuez-dashboard
# Optional: when set, Next.js API routes proxy to the standalone FastAPI service.
# BIOHUEZ_API_BASE_URL=http://localhost:8000
# Optional but recommended in production: same value on Vercel and FastAPI.
# BIOHUEZ_API_KEY=
# Optional: comma-separated frontend origins allowed by FastAPI CORS.
# BIOHUEZ_ALLOWED_ORIGINS=http://localhost:3001
# Optional: override Python if the legacy dashboard venv is not at ./venv/bin/python3
# BIOHUEZ_PYTHON=../biohuez-dashboard/venv/bin/python3
# Optional: set this when reading from MotherDuck instead of local biohuez.db
# MOTHERDUCK_TOKEN=

# SP-API credentials. Keep real values in .env.local only.
# SP_API_REFRESH_TOKEN=
# SP_API_LWA_APP_ID=
# SP_API_LWA_CLIENT_SECRET=
# SP_API_ROLE_ARN=
# SP_API_MARKETPLACE=US
# SP_API_MARKETPLACE_ID=ATVPDKIKX0DER

# Amazon Ads API credentials. Keep real values in .env.local only.
# ADS_CLIENT_ID=
# ADS_CLIENT_SECRET=
# ADS_REDIRECT_URI=
# ADS_REFRESH_TOKEN=
# ADS_PROFILE_ID=
# ADS_REGION=NA
